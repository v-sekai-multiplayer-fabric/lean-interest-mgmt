    given-names: "K. S. Ernest (iFire)"
    email: ernest.lee@chibifire.com
    orcid: "https://orcid.org/0000-0003-4570-1436"
version: 0.1.0-dev.1
date-released: "2026-06-25"
license: MIT
repository-code: "https://github.com/v-sekai-multiplayer-fabric/lean-interest-mgmt"
keywords:
  - lean4
  - formal-verification
  - interest-management
  - aoi
  - zone
  - multiplayer

